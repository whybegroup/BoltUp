# This `.xcode.env` file is versioned and is used to source the environment
# used when running script phases inside Xcode.
# To customize your local environment, you can create an `.xcode.env.local`
# file that is not versioned.

# NODE_BINARY must be an absolute path. Xcode script phases use /bin/sh with a
# minimal PATH, so `command -v node` is often empty when Node comes from nvm/fnm.
# Set NODE_BINARY explicitly in `.xcode.env.local` if auto-detection fails.

if [[ -z "$NODE_BINARY" ]] || [[ ! -x "$NODE_BINARY" ]]; then
  # bash 3.2 + set -e: $(command -v …) exits the shell when the command returns 1.
  _node_from_path="$(command -v node 2>/dev/null || true)"
  if [[ -n "$_node_from_path" ]] && [[ -x "$_node_from_path" ]]; then
    export NODE_BINARY="$_node_from_path"
  fi
fi

if [[ -z "$NODE_BINARY" ]] || [[ ! -x "$NODE_BINARY" ]]; then
  _nvm_root="${NVM_DIR:-$HOME/.nvm}/versions/node"
  if [[ -d "$_nvm_root" ]]; then
    _latest=""
    _latest="$(ls -1 "$_nvm_root" 2>/dev/null | sort -V | tail -1)" || true
    if [[ -n "$_latest" ]] && [[ -x "$_nvm_root/$_latest/bin/node" ]]; then
      export NODE_BINARY="$_nvm_root/$_latest/bin/node"
    fi
  fi
fi

if [[ -z "$NODE_BINARY" ]] || [[ ! -x "$NODE_BINARY" ]]; then
  for _p in /opt/homebrew/bin/node /usr/local/bin/node; do
    if [[ -x "$_p" ]]; then
      export NODE_BINARY="$_p"
      break
    fi
  done
fi

unset _node_from_path _nvm_root _latest _p
